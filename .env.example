# PostgreSQL 접속 정보 (직접 만든 DB로 교체)
DATABASE_URL=postgresql+psycopg2://wayfinder:wayfinder@localhost:5432/wayfinder

# JWT 설정 — secret은 최소 32바이트 이상, 배포 전 무작위 값으로 교체하고 git에 커밋하지 말 것
JWT_SECRET=wayfinder-dev-secret-key-change-me-before-deploy-please-32bytes
JWT_EXPIRATION_MINUTES=1440

# 프론트 개발 서버 CORS 허용
CORS_ORIGINS=http://localhost:5173
